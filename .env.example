# VDP Postgres connection string.
# Format: postgresql://user:password@127.0.0.1:16380/database?sslmode=disable
#
# Before starting the app, run the Fly.io proxy tunnel in a separate terminal:
#   fly proxy 16380:5432 -a <app-name>
#
DATABASE_URL=postgresql://user:password@127.0.0.1:16380/vdp?sslmode=disable
